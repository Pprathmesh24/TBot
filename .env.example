# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# OANDA demo credentials (needed from Phase 7)
OANDA__ACCOUNT_ID=your-account-id-here
OANDA__API_TOKEN=your-api-token-here
OANDA__ENVIRONMENT=practice

# FRED API key — free at fred.stlouisfed.org/docs/api/api_key.html (needed for Phase 9)
FRED_API_KEY=your-fred-key-here

# Slack Incoming Webhook URL — from api.slack.com/apps → Incoming Webhooks (Phase 8)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
